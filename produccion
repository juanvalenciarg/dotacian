  <style>
    .production-steps {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 2.5rem;
      position: relative;
      padding: 0 1rem;
    }

    .production-steps::before {
      content: "";
      position: absolute;
      top: 2rem;
      left: 2rem;
      right: 2rem;
      height: 2px;
      background: var(--color-border);
      z-index: 0;
    }

    .step-node {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      z-index: 1;
      position: relative;
    }

    .step-indicator {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: white;
      border: 2px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.75rem;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-text-muted);
      transition: all 0.3s ease;
    }

    .step-node.completed .step-indicator {
      background: var(--color-cyan);
      border-color: var(--color-cyan);
      color: white;
    }

    .step-node.active .step-indicator {
      border-color: var(--color-cyan);
      color: var(--color-cyan);
      box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.1);
    }

    .step-node.active .step-title {
      color: var(--color-cyan);
    }

    .step-title {
      font-family: var(--font-family-heading);
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--color-navy);
      margin-bottom: 0.25rem;
    }

    .step-desc {
      font-size: 0.75rem;
      color: var(--color-text-secondary);
      max-width: 140px;
    }

    .progress-track {
      height: 8px;
      background: var(--color-smoke-mid);
      border-radius: 4px;
      margin-top: 0.75rem;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--color-cyan), #0ea5e9);
      border-radius: 4px;
      transition: width 0.5s ease;
    }

    .mini-stepper {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 0.75rem;
      position: relative;
      padding: 0 4px;
    }

    .mini-stepper::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--color-border);
      transform: translateY(-50%);
      z-index: 0;
    }

    .mini-step {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: white;
      border: 2px solid var(--color-border);
      z-index: 1;
      position: relative;
      transition: all 0.3s;
    }

    .mini-step.completed {
      background: var(--color-cyan);
      border-color: var(--color-cyan);
    }

    .mini-step.active {
      background: white;
      border-color: var(--color-cyan);
      box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.2);
    }

    .order-card-mini {
      padding: 1.25rem;
      background: white;
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      transition: all 0.2s;
    }

    .order-card-mini:hover {
      border-color: var(--color-cyan);
      background: white;
    }

    .production-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .summary-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .summary-item:last-child {
      border-bottom: none;
    }

    .item-info {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .item-thumb {
      width: 48px;
      height: 48px;
      background: var(--color-smoke-mid);
      border-radius: 8px;
      padding: 4px;
    }

    .item-thumb img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .item-name {
      font-weight: 600;
      color: var(--color-navy);
      font-size: 0.9375rem;
    }

    .item-meta {
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    .order-status {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      font-weight: 600;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .dot-warning { background-color: #F59E0B; }
    .dot-success { background-color: #10B981; }
    .dot-info { background-color: var(--color-cyan); }
  </style>
